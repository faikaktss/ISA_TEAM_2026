<?xml version="1.0"?>
<!--
  =====================================================
  KİŞİ 1 İÇİN TEMPLATE: OTONOM ARAÇ URDF MODELİ
  =====================================================
  
  GÖREV: Bu dosyayı doldurun
  - Araç gövdesini (chassis) tanımlayın
  - 4 tekerleği ekleyin (ön 2, arka 2)
  - Kameraları ekleyin (2 adet - lane detection + sign recognition)
  - Lidar'ı ekleyin
  - Ackermann kinematik parametrelerini ayarlayın
  
  ARAÇ SPESİFİKASYONLARI:
  - Boyutlar: 2.22m (uzunluk) x 1.35m (genişlik) x 1.70m (yükseklik)
  - Ağırlık: 300kg
  - Wheelbase (dingil mesafesi): 1.52m
  - Track width: Ön 1.43m, Arka 1.22m
  - Tekerlek çapı: 0.46m, kalınlık: 0.11m
  - Direksiyon açısı: ±45°
  
  TAMAMLANACAK BÖLÜMLER:
  1. Chassis (gövde) inertia değerlerini hesaplayın
  2. Tekerlek joint'lerini tanımlayın
  3. Kamera ve Lidar sensor plugin'lerini ekleyin
  4. Ackermann controller plugin'ini yapılandırın
-->

<robot name="otonom_arac" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ============================================= -->
  <!-- PROPERTY TANIMLARI (Sabitler) -->
  <!-- ============================================= -->
  
  <xacro:property name="chassis_length" value="2.22"/>
  <xacro:property name="chassis_width" value="1.35"/>
  <xacro:property name="chassis_height" value="1.70"/>
  <xacro:property name="chassis_mass" value="250.0"/>  <!-- Toplam 300kg - tekerlekler 50kg -->
  
  <xacro:property name="wheelbase" value="1.52"/>
  <xacro:property name="track_width_front" value="1.43"/>
  <xacro:property name="track_width_rear" value="1.22"/>
  
  <xacro:property name="wheel_radius" value="0.23"/>  <!-- 46cm çap = 23cm yarıçap -->
  <xacro:property name="wheel_thickness" value="0.11"/>
  <xacro:property name="wheel_mass" value="12.5"/>  <!-- 4 tekerlek = 50kg -->
  
  <xacro:property name="max_steering_angle" value="0.785"/>  <!-- 45° = 0.785 radyan -->
  
  <!-- Renkler -->
  <material name="blue">
    <color rgba="0.2 0.2 0.8 1.0"/>
  </material>
  <material name="black">
    <color rgba="0.1 0.1 0.1 1.0"/>
  </material>
  <material name="gray">
    <color rgba="0.5 0.5 0.5 1.0"/>
  </material>


  <!-- ============================================= -->
  <!-- CHASSIS (ANA GÖVDE) -->
  <!-- ============================================= -->
  
  <link name="base_link"/>
  
  <joint name="base_to_chassis" type="fixed">
    <parent link="base_link"/>
    <child link="chassis"/>
    <origin xyz="0 0 ${wheel_radius}" rpy="0 0 0"/>
  </joint>
  
  <link name="chassis">
    <visual>
      <origin xyz="0 0 ${chassis_height/2}" rpy="0 0 0"/>
      <geometry>
        <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
      </geometry>
      <material name="blue"/>
    </visual>
    
    <collision>
      <origin xyz="0 0 ${chassis_height/2}" rpy="0 0 0"/>
      <geometry>
        <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
      </geometry>
    </collision>
    
    <inertial>
      <origin xyz="0 0 ${chassis_height/2}" rpy="0 0 0"/>
      <mass value="${chassis_mass}"/>
      <!-- TODO KİŞİ 1: Inertia tensorünü hesaplayın -->
      <!-- Box inertia: Ixx = m/12 * (h² + d²), Iyy = m/12 * (l² + h²), Izz = m/12 * (l² + d²) -->
      <inertia 
        ixx="${chassis_mass/12 * (chassis_height*chassis_height + chassis_width*chassis_width)}"
        iyy="${chassis_mass/12 * (chassis_length*chassis_length + chassis_height*chassis_height)}"
        izz="${chassis_mass/12 * (chassis_length*chassis_length + chassis_width*chassis_width)}"
        ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>


  <!-- ============================================= -->
  <!-- TEKERLEK MAKROLARI -->
  <!-- ============================================= -->
  
  <xacro:macro name="wheel" params="prefix parent x_offset y_offset z_offset">
    <link name="${prefix}_wheel">
      <visual>
        <origin xyz="0 0 0" rpy="1.5708 0 0"/>  <!-- 90° döndür (yatay tekerlek) -->
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_thickness}"/>
        </geometry>
        <material name="black"/>
      </visual>
      
      <collision>
        <origin xyz="0 0 0" rpy="1.5708 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_thickness}"/>
        </geometry>
      </collision>
      
      <inertial>
        <origin xyz="0 0 0" rpy="1.5708 0 0"/>
        <mass value="${wheel_mass}"/>
        <!-- Silindir inertia: Ixx=Iyy = m/12 * (3r² + h²), Izz = m/2 * r² -->
        <inertia 
          ixx="${wheel_mass/12 * (3*wheel_radius*wheel_radius + wheel_thickness*wheel_thickness)}"
          iyy="${wheel_mass/12 * (3*wheel_radius*wheel_radius + wheel_thickness*wheel_thickness)}"
          izz="${wheel_mass/2 * wheel_radius*wheel_radius}"
          ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>
    
    <!-- TODO KİŞİ 1: Joint tipini ayarlayın -->
    <!-- Ön tekerlekler için: continuous (sürekli dönüş) -->
    <!-- Arka tekerlekler için: continuous (motorlu) -->
    <joint name="${prefix}_wheel_joint" type="continuous">
      <parent link="${parent}"/>
      <child link="${prefix}_wheel"/>
      <origin xyz="${x_offset} ${y_offset} ${z_offset}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>  <!-- Y ekseni etrafında dönüş -->
    </joint>
  </xacro:macro>


  <!-- ============================================= -->
  <!-- DİREKSİYON LİNKLERİ (Ackermann için) -->
  <!-- ============================================= -->
  
  <!-- Sol ön direksiyon -->
  <link name="front_left_steering_link"/>
  
  <joint name="front_left_steering_joint" type="revolute">
    <parent link="chassis"/>
    <child link="front_left_steering_link"/>
    <origin xyz="${wheelbase/2} ${track_width_front/2} 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>  <!-- Z ekseni etrafında direksiyon -->
    <limit lower="${-max_steering_angle}" upper="${max_steering_angle}" 
           effort="100" velocity="1.0"/>
  </joint>
  
  <!-- Sağ ön direksiyon -->
  <link name="front_right_steering_link"/>
  
  <joint name="front_right_steering_joint" type="revolute">
    <parent link="chassis"/>
    <child link="front_right_steering_link"/>
    <origin xyz="${wheelbase/2} ${-track_width_front/2} 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="${-max_steering_angle}" upper="${max_steering_angle}" 
           effort="100" velocity="1.0"/>
  </joint>


  <!-- ============================================= -->
  <!-- TEKERLEKLER -->
  <!-- ============================================= -->
  
  <!-- Ön Tekerlekler (direksiyon linklerine bağlı) -->
  <xacro:wheel prefix="front_left" parent="front_left_steering_link" 
               x_offset="0" y_offset="0" z_offset="0"/>
  <xacro:wheel prefix="front_right" parent="front_right_steering_link" 
               x_offset="0" y_offset="0" z_offset="0"/>
  
  <!-- Arka Tekerlekler (chassis'e doğrudan bağlı) -->
  <xacro:wheel prefix="rear_left" parent="chassis" 
               x_offset="${-wheelbase/2}" y_offset="${track_width_rear/2}" z_offset="0"/>
  <xacro:wheel prefix="rear_right" parent="chassis" 
               x_offset="${-wheelbase/2}" y_offset="${-track_width_rear/2}" z_offset="0"/>


  <!-- ============================================= -->
  <!-- KAMERALAR -->
  <!-- ============================================= -->
  
  <!-- Kamera 1: Lane Detection (aşağı bakıyor) -->
  <link name="camera_lane_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.05 0.05"/>
      </geometry>
      <material name="gray"/>
    </visual>
    
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.05 0.05"/>
      </geometry>
    </collision>
    
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" iyy="0.0001" izz="0.0001" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>
  
  <joint name="camera_lane_joint" type="fixed">
    <parent link="chassis"/>
    <child link="camera_lane_link"/>
    <!-- TODO KİŞİ 1: Kamera pozisyonunu ayarlayın (üstte, aşağı bakacak şekilde) -->
    <origin xyz="0.5 0 ${chassis_height}" rpy="0 0.785 0"/>  <!-- 45° aşağı -->
  </joint>
  
  <!-- Kamera 2: Sign Recognition (öne bakıyor) -->
  <link name="camera_sign_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.05 0.05"/>
      </geometry>
      <material name="gray"/>
    </visual>
    
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.05 0.05"/>
      </geometry>
    </collision>
    
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" iyy="0.0001" izz="0.0001" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>
  
  <joint name="camera_sign_joint" type="fixed">
    <parent link="chassis"/>
    <child link="camera_sign_link"/>
    <!-- TODO KİŞİ 1: Kamera pozisyonunu ayarlayın (üstte, öne bakacak şekilde) -->
    <origin xyz="0.8 0 ${chassis_height}" rpy="0 0 0"/>  <!-- Düz öne -->
  </joint>


  <!-- ============================================= -->
  <!-- LIDAR -->
  <!-- ============================================= -->
  
  <link name="lidar_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.1"/>
      </geometry>
      <material name="black"/>
    </visual>
    
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.1"/>
      </geometry>
    </collision>
    
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.0001" iyy="0.0001" izz="0.0001" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>
  
  <joint name="lidar_joint" type="fixed">
    <parent link="chassis"/>
    <child link="lidar_link"/>
    <!-- TODO KİŞİ 1: Lidar pozisyonunu ayarlayın (en üstte, merkez) -->
    <origin xyz="0 0 ${chassis_height + 0.05}" rpy="0 0 0"/>
  </joint>


  <!-- ============================================= -->
  <!-- GAZEBO PLUGIN'LERİ -->
  <!-- ============================================= -->
  
  <!-- TODO KİŞİ 1: Aşağıdaki plugin'leri aktif edin -->
  
  <!-- Ackermann Drive Controller -->
  <gazebo>
    <plugin name="ackermann_drive" filename="libgazebo_ros_ackermann_drive.so">
      
      <!-- Wheel joints -->
      <front_left_joint>front_left_steering_joint</front_left_joint>
      <front_right_joint>front_right_steering_joint</front_right_joint>
      <rear_left_joint>rear_left_wheel_joint</rear_left_joint>
      <rear_right_joint>rear_right_wheel_joint</rear_right_joint>
      
      <!-- Steering joints -->
      <front_left_steering_joint>front_left_steering_joint</front_left_steering_joint>
      <front_right_steering_joint>front_right_steering_joint</front_right_steering_joint>
      
      <!-- Kinematics -->
      <wheel_separation>${track_width_rear}</wheel_separation>
      <wheelbase>${wheelbase}</wheelbase>
      <wheel_diameter>${wheel_radius * 2}</wheel_diameter>
      
      <!-- Limits -->
      <max_steer>${max_steering_angle}</max_steer>
      <max_steering_angle>${max_steering_angle}</max_steering_angle>
      <max_speed>5.0</max_speed>
      
      <!-- Topics -->
      <command_topic>/cmd_vel</command_topic>
      <odometry_topic>/odom</odometry_topic>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_link</robot_base_frame>
      
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>true</publish_wheel_tf>
      
      <update_rate>50.0</update_rate>
      
    </plugin>
  </gazebo>
  
  <!-- Lane Detection Camera Plugin -->
  <gazebo reference="camera_lane_link">
    <sensor type="camera" name="camera_lane">
      <update_rate>30.0</update_rate>
      <camera name="lane_camera">
        <horizontal_fov>1.3962634</horizontal_fov>  <!-- 80° -->
        <image>
          <width>1280</width>
          <height>720</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.1</near>
          <far>100</far>
        </clip>
      </camera>
      
      <plugin name="camera_lane_controller" filename="libgazebo_ros_camera.so">
        <alwaysOn>true</alwaysOn>
        <updateRate>30.0</updateRate>
        <cameraName>camera/lane</cameraName>
        <imageTopicName>/camera/lane/image_raw</imageTopicName>
        <cameraInfoTopicName>/camera/lane/camera_info</cameraInfoTopicName>
        <frameName>camera_lane_link</frameName>
      </plugin>
    </sensor>
  </gazebo>
  
  <!-- Sign Recognition Camera Plugin -->
  <gazebo reference="camera_sign_link">
    <sensor type="camera" name="camera_sign">
      <update_rate>30.0</update_rate>
      <camera name="sign_camera">
        <horizontal_fov>1.3962634</horizontal_fov>
        <image>
          <width>1280</width>
          <height>720</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.1</near>
          <far>100</far>
        </clip>
      </camera>
      
      <plugin name="camera_sign_controller" filename="libgazebo_ros_camera.so">
        <alwaysOn>true</alwaysOn>
        <updateRate>30.0</updateRate>
        <cameraName>camera/sign</cameraName>
        <imageTopicName>/camera/sign/image_raw</imageTopicName>
        <cameraInfoTopicName>/camera/sign/camera_info</cameraInfoTopicName>
        <frameName>camera_sign_link</frameName>
      </plugin>
    </sensor>
  </gazebo>
  
  <!-- Lidar Plugin -->
  <gazebo reference="lidar_link">
    <sensor type="ray" name="lidar">
      <pose>0 0 0 0 0 0</pose>
      <visualize>true</visualize>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>0.0</min_angle>
            <max_angle>6.28319</max_angle>  <!-- 360° -->
          </horizontal>
        </scan>
        <range>
          <min>0.15</min>
          <max>12.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </ray>
      
      <plugin name="lidar_controller" filename="libgazebo_ros_ray_sensor.so">
        <ros>
          <namespace>/</namespace>
          <remapping>~/out:=/scan</remapping>
        </ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>lidar_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>
  
  <!-- Gazebo Malzeme Ayarları -->
  <gazebo reference="chassis">
    <material>Gazebo/Blue</material>
  </gazebo>
  
  <gazebo reference="front_left_wheel">
    <material>Gazebo/Black</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
  </gazebo>
  
  <gazebo reference="front_right_wheel">
    <material>Gazebo/Black</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
  </gazebo>
  
  <gazebo reference="rear_left_wheel">
    <material>Gazebo/Black</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
  </gazebo>
  
  <gazebo reference="rear_right_wheel">
    <material>Gazebo/Black</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
  </gazebo>

</robot>
