<?xml version="1.0"?>
<!--
  =====================================================
  KİŞİ 2 İÇİN TEMPLATE: GAZEBo TEST PİSTİ
  =====================================================
  
  GÖREV: Bu dosyayı doldurun
  - Zemin (ground plane) oluşturun
  - Şerit çizgileriyle yol dokusu ekleyin
  - Trafik işaretleri yerleştirin
  - Engeller ekleyin (koniler, bariyerler)
  - Işıklandırma ayarlayın
  
  GEREKSİNİMLER:
  - Yol genişliği: 3-4 metre (ISA yarışması standartları)
  - Şerit çizgileri: Beyaz kesikli çizgiler
  - Trafik işaretleri: Dur, Hız limiti, Dönüş işaretleri
  - Test senaryoları: Düz yol, viraj, park, engel
  
  TAMAMLANACAK BÖLÜMLER:
  1. Yol dokusu (texture) ekleyin
  2. Model kütüphanesinden işaret ekleyin
  3. Engel yerleşimi yapın
  4. Kamera açısını ayarlayın
-->

<sdf version="1.6">
  <world name="test_track_world">
    
    <!-- ============================================= -->
    <!-- FİZİK AYARLARI -->
    <!-- ============================================= -->
    
    <physics type="ode">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
      <real_time_update_rate>1000.0</real_time_update_rate>
      <gravity>0 0 -9.81</gravity>
    </physics>
    
    
    <!-- ============================================= -->
    <!-- IŞIKLANDIRMA -->
    <!-- ============================================= -->
    
    <!-- Güneş ışığı -->
    <include>
      <uri>model://sun</uri>
    </include>
    
    <!-- Ortam ışığı -->
    <light name="ambient_light" type="ambient">
      <cast_shadows>false</cast_shadows>
      <diffuse>0.7 0.7 0.7 1</diffuse>
      <specular>0.1 0.1 0.1 1</specular>
      <direction>0.5 0.5 -1.0</direction>
    </light>
    
    <!-- Nokta ışık kaynağı -->
    <light name="point_light" type="point">
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.5 0.5 0.5 1</diffuse>
      <specular>0.1 0.1 0.1 1</specular>
      <attenuation>
        <range>50</range>
        <constant>0.5</constant>
        <linear>0.01</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
      <cast_shadows>false</cast_shadows>
    </light>
    
    
    <!-- ============================================= -->
    <!-- ZEMİN (GROUND PLANE) -->
    <!-- ============================================= -->
    
    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>100 100</size>
            </plane>
          </geometry>
          <surface>
            <friction>
              <ode>
                <mu>100</mu>
                <mu2>50</mu2>
              </ode>
            </friction>
          </surface>
        </collision>
        
        <visual name="visual">
          <cast_shadows>false</cast_shadows>
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>100 100</size>
            </plane>
          </geometry>
          <material>
            <ambient>0.3 0.3 0.3 1</ambient>
            <diffuse>0.7 0.7 0.7 1</diffuse>
            <specular>0.01 0.01 0.01 1</specular>
          </material>
        </visual>
      </link>
    </model>
    
    
    <!-- ============================================= -->
    <!-- YOL DOKUSU (ŞERIT ÇİZGİLERİ İLE) -->
    <!-- ============================================= -->
    
    <!-- TODO KİŞİ 2: Aşağıya gerçek yol dokusu ekleyin -->
    <!-- Seçenek 1: Hazır texture kullanın (road.png dosyası) -->
    <!-- Seçenek 2: Box'larla şerit çizgileri oluşturun -->
    
    <!-- Ana Yol -->
    <model name="road_straight">
      <static>true</static>
      <pose>10 0 0.01 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box>
              <size>20 4 0.01</size>
            </box>
          </geometry>
        </collision>
        
        <visual name="visual">
          <geometry>
            <box>
              <size>20 4 0.01</size>
            </box>
          </geometry>
          <material>
            <ambient>0.2 0.2 0.2 1</ambient>
            <diffuse>0.3 0.3 0.3 1</diffuse>
            <!-- TODO KİŞİ 2: Texture ekleyin -->
            <!-- <script>
              <uri>file://media/materials/scripts/road.material</uri>
              <name>Road/Asphalt</name>
            </script> -->
          </material>
        </visual>
      </link>
    </model>
    
    <!-- Şerit Çizgileri (Beyaz Kesikli) -->
    <!-- Sol şerit -->
    <model name="lane_line_left_1">
      <static>true</static>
      <pose>5 1 0.02 0 0 0</pose>
      <link name="link">
        <visual name="visual">
          <geometry>
            <box>
              <size>2 0.1 0.01</size>
            </box>
          </geometry>
          <material>
            <ambient>1 1 1 1</ambient>
            <diffuse>1 1 1 1</diffuse>
          </material>
        </visual>
      </link>
    </model>
    
    <model name="lane_line_left_2">
      <static>true</static>
      <pose>10 1 0.02 0 0 0</pose>
      <link name="link">
        <visual name="visual">
          <geometry>
            <box>
              <size>2 0.1 0.01</size>
            </box>
          </geometry>
          <material>
            <ambient>1 1 1 1</ambient>
            <diffuse>1 1 1 1</diffuse>
          </material>
        </visual>
      </link>
    </model>
    
    <model name="lane_line_left_3">
      <static>true</static>
      <pose>15 1 0.02 0 0 0</pose>
      <link name="link">
        <visual name="visual">
          <geometry>
            <box>
              <size>2 0.1 0.01</size>
            </box>
          </geometry>
          <material>
            <ambient>1 1 1 1</ambient>
            <diffuse>1 1 1 1</diffuse>
          </material>
        </visual>
      </link>
    </model>
    
    <!-- Sağ şerit (aynı şekilde) -->
    <model name="lane_line_right_1">
      <static>true</static>
      <pose>5 -1 0.02 0 0 0</pose>
      <link name="link">
        <visual name="visual">
          <geometry>
            <box>
              <size>2 0.1 0.01</size>
            </box>
          </geometry>
          <material>
            <ambient>1 1 1 1</ambient>
            <diffuse>1 1 1 1</diffuse>
          </material>
        </visual>
      </link>
    </model>
    
    <model name="lane_line_right_2">
      <static>true</static>
      <pose>10 -1 0.02 0 0 0</pose>
      <link name="link">
        <visual name="visual">
          <geometry>
            <box>
              <size>2 0.1 0.01</size>
            </box>
          </geometry>
          <material>
            <ambient>1 1 1 1</ambient>
            <diffuse>1 1 1 1</diffuse>
          </material>
        </visual>
      </link>
    </model>
    
    <!-- TODO KİŞİ 2: Daha fazla şerit çizgisi ekleyin -->
    
    
    <!-- ============================================= -->
    <!-- TRAFİK İŞARETLERİ -->
    <!-- ============================================= -->
    
    <!-- TODO KİŞİ 2: Gazebo model kütüphanesinden işaretler ekleyin -->
    
    <!-- Örnek: Dur İşareti -->
    <model name="stop_sign">
      <static>true</static>
      <pose>15 3 0 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box>
              <size>0.05 0.6 0.6</size>
            </box>
          </geometry>
        </collision>
        
        <visual name="visual">
          <geometry>
            <box>
              <size>0.05 0.6 0.6</size>
            </box>
          </geometry>
          <material>
            <ambient>0.8 0.1 0.1 1</ambient>
            <diffuse>0.8 0.1 0.1 1</diffuse>
          </material>
        </visual>
        
        <!-- Direk -->
        <visual name="pole">
          <pose>0 0 -0.5 0 0 0</pose>
          <geometry>
            <cylinder>
              <radius>0.03</radius>
              <length>1.0</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.5 0.5 0.5 1</ambient>
            <diffuse>0.5 0.5 0.5 1</diffuse>
          </material>
        </visual>
      </link>
    </model>
    
    <!-- TODO KİŞİ 2: Hız limiti, dönüş işaretleri vs. ekleyin -->
    
    
    <!-- ============================================= -->
    <!-- ENGELLER -->
    <!-- ============================================= -->
    
    <!-- Koni 1 -->
    <model name="cone_1">
      <static>true</static>
      <pose>8 -1.5 0 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <cylinder>
              <radius>0.15</radius>
              <length>0.5</length>
            </cylinder>
          </geometry>
        </collision>
        
        <visual name="visual">
          <geometry>
            <cylinder>
              <radius>0.15</radius>
              <length>0.5</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>1 0.5 0 1</ambient>
            <diffuse>1 0.5 0 1</diffuse>
          </material>
        </visual>
      </link>
    </model>
    
    <model name="cone_2">
      <static>true</static>
      <pose>12 1.5 0 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <cylinder>
              <radius>0.15</radius>
              <length>0.5</length>
            </cylinder>
          </geometry>
        </collision>
        
        <visual name="visual">
          <geometry>
            <cylinder>
              <radius>0.15</radius>
              <length>0.5</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>1 0.5 0 1</ambient>
            <diffuse>1 0.5 0 1</diffuse>
          </material>
        </visual>
      </link>
    </model>
    
    <!-- TODO KİŞİ 2: Daha fazla engel ekleyin (bariyerler, kutular vs.) -->
    
    
    <!-- ============================================= -->
    <!-- VİRAJ BÖLÜMÜ -->
    <!-- ============================================= -->
    
    <!-- TODO KİŞİ 2: Virajlı yol segmenti ekleyin -->
    <!-- İpucu: Box'ları rotate ederek viraj oluşturabilirsiniz -->
    
    
    <!-- ============================================= -->
    <!-- GUI AYARLARI -->
    <!-- ============================================= -->
    
    <gui fullscreen='0'>
      <camera name='user_camera'>
        <pose>-5 -5 3 0 0.3 0.78</pose>
        <view_controller>orbit</view_controller>
        <projection_type>perspective</projection_type>
      </camera>
    </gui>
    
    
    <!-- ============================================= -->
    <!-- GAZEBO PLUGINS -->
    <!-- ============================================= -->
    
    <!-- ROS Interface Plugin -->
    <plugin name="gazebo_ros_state" filename="libgazebo_ros_state.so">
      <ros>
        <namespace>/gazebo</namespace>
      </ros>
      <update_rate>10.0</update_rate>
    </plugin>
    
  </world>
</sdf>
